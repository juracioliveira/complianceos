# ============================================================
# ComplianceOS — Variáveis de Ambiente
# Copiar para .env.local e preencher os valores
# NUNCA commitar .env.local — ver .gitignore
# ============================================================

# --- APLICAÇÃO ---
NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0
API_LOG_LEVEL=debug
API_BASE_URL=http://localhost:4000

WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_ENV=development

# --- BANCO DE DADOS ---
# Conexão app (runtime) — role compliance_app
DATABASE_URL=postgresql://compliance_app:app_password_dev@localhost:5432/compliance

# Conexão migrator — role compliance_migrator (apenas para migrations)
DATABASE_MIGRATOR_URL=postgresql://compliance_migrator:migrator_password_dev@localhost:5432/compliance

# Configurações de pool
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT=30000

# --- REDIS ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- AUTENTICAÇÃO JWT (RS256) ---
# Gerar: openssl genrsa -out private.pem 4096 && openssl rsa -in private.pem -pubout -out public.pem
# Colar o conteúdo base64: base64 -w0 private.pem
JWT_PRIVATE_KEY_BASE64=GERAR_COM_OPENSSL
JWT_PUBLIC_KEY_BASE64=GERAR_COM_OPENSSL
JWT_ACCESS_TOKEN_EXPIRY=900       # 15 minutos em segundos
JWT_REFRESH_TOKEN_EXPIRY=604800   # 7 dias em segundos

# --- BCRYPT ---
BCRYPT_ROUNDS=12

# --- TOTP MFA ---
TOTP_ISSUER=ComplianceOS
# Chave AES-256 para criptografar mfa_secret no banco (32 bytes base64)
MFA_ENCRYPTION_KEY=GERAR_32_BYTES_ALEATORIOS_BASE64

# --- EMAIL (Brevo/SMTP) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=SEU_EMAIL_BREVO
SMTP_PASS=SUA_API_KEY_BREVO
EMAIL_FROM="ComplianceOS <noreply@complianceos.com.br>"
EMAIL_REPLY_TO=suporte@complianceos.com.br

# --- AWS (para S3, SES, etc.) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=SEU_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=SUA_SECRET_KEY

# S3 — documentos gerados
S3_BUCKET_DOCUMENTS=compliance-documents-dev
S3_BUCKET_EVIDENCE=compliance-evidence-dev
S3_PRESIGNED_URL_EXPIRY=900     # 15 minutos

# --- RATE LIMITING ---
RATE_LIMIT_STARTER=120          # req/min
RATE_LIMIT_PROFESSIONAL=600
RATE_LIMIT_ENTERPRISE=3000

# --- FILAS (BullMQ) ---
QUEUE_DOCUMENT_GENERATION=document-generation
QUEUE_RISK_SCORING=risk-scoring
QUEUE_NOTIFICATIONS=notifications
QUEUE_KYB=kyb-validation

# --- INTEGRAÇÕES EXTERNAS (stubs em dev) ---
# Screening de sanções (OFAC, ONU, etc.)
SANCTIONS_API_URL=https://api.sanctions.example.com
SANCTIONS_API_KEY=STUB_DEV

# KYB — validação de CNPJ (Receita Federal proxy)
KYB_API_URL=https://api.kyb.example.com
KYB_API_KEY=STUB_DEV

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# --- SESSÃO / SEGURANÇA ---
COOKIE_SECRET=GERAR_MINIMO_32_CHARS_ALEATORIOS
SESSION_DOMAIN=localhost

# --- FEATURE FLAGS ---
FF_WEBHOOKS_ENABLED=false
FF_SANCTIONS_SCREENING_ENABLED=false
FF_DOCUMENT_GENERATION_ENABLED=true
