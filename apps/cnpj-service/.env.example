# App
NODE_ENV=development
PORT=4001
LOG_LEVEL=info

# Banco
DATABASE_URL=postgresql://cnpj:cnpj123@localhost:5432/cnpj_rfb
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Segurança
CNPJ_API_KEY=troque-em-producao
CNPJ_ADMIN_KEY=troque-em-producao

# ETL
RFB_BASE_URL=https://arquivos.receitafederal.gov.br/dados/cnpj/dados_abertos_cnpj
RFB_DOWNLOAD_DIR=/tmp/rfb
RFB_DOWNLOAD_CONCURRENCY=3         # ZIPs em paralelo
RFB_DOWNLOAD_RETRIES=5

# Sync
SYNC_CRON="0 3 5 * *"               # dia 5 às 3h
SYNC_FORCE_COMPETENCIA=
