{
    "name": "@compliance-os/cnpj-service",
    "version": "1.0.0",
    "description": "API REST para consulta de CNPJ com dados direto da Receita Federal do Brasil",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsup src/server.ts --format esm --clean",
        "start": "tsx src/db/migrate.ts && node dist/server.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --ext .ts",
        "test": "vitest run tests/unit",
        "test:integration": "vitest run tests/integration",
        "sync:run": "tsx src/jobs/sync.job.ts",
        "db:migrate": "tsx src/db/migrate.ts"
    },
    "dependencies": {
        "@fastify/rate-limit": "^9.1.0",
        "bullmq": "^5.4.2",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.30.10",
        "fastify": "^4.27.0",
        "got": "^14.2.1",
        "iconv-lite": "^0.6.3",
        "ioredis": "^5.3.2",
        "p-limit": "^5.0.0",
        "pg": "^8.11.5",
        "pg-copy-streams": "^6.0.6",
        "pino": "^9.1.0",
        "undici": "^6.11.1",
        "unzipper": "^0.11.4",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@testcontainers/postgresql": "^10.7.2",
        "@testcontainers/redis": "^10.7.2",
        "@types/iconv-lite": "^0.0.1",
        "@types/node": "^20.12.12",
        "@types/pg": "^8.11.6",
        "@types/pg-copy-streams": "^1.2.5",
        "@types/unzipper": "^0.10.9",
        "drizzle-kit": "^0.20.18",
        "testcontainers": "^10.7.2",
        "tsup": "^8.0.2",
        "tsx": "^4.10.5",
        "typescript": "^5.4.5",
        "vitest": "^1.6.0"
    }
}