{
    "name": "@compliance-os/api",
    "version": "1.0.0",
    "description": "ComplianceOS — API Backend (Fastify)",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch --env-file=../../.env.local src/server.ts",
        "build": "tsup",
        "start": "tsx src/infra/db/migrate.ts && node dist/server.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --ext .ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:integration": "vitest run --config vitest.integration.ts",
        "clean": "rimraf dist",
        "db:migrate": "tsx --env-file=../../.env.local src/infra/db/migrate.ts",
        "db:migrate:create": "tsx --env-file=../../.env.local src/infra/db/migrate-create.ts",
        "db:migrate:status": "tsx --env-file=../../.env.local src/infra/db/migrate-status.ts",
        "db:migrate:rollback": "tsx --env-file=../../.env.local src/infra/db/migrate-rollback.ts",
        "db:seed": "tsx --env-file=../../.env.local src/infra/db/seed.ts",
        "db:seed:prod": "tsx src/infra/db/seed.ts",
        "db:reset": "tsx --env-file=../../.env.local src/infra/db/reset.ts",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@compliance-os/checklist-engine": "workspace:*",
        "@compliance-os/scoring-engine": "workspace:*",
        "@compliance-os/types": "workspace:*",
        "@fastify/cookie": "^9.4.0",
        "@fastify/cors": "^9.0.1",
        "@fastify/helmet": "^11.1.1",
        "@fastify/jwt": "^8.0.1",
        "@fastify/rate-limit": "^9.1.0",
        "@fastify/swagger": "^8.14.0",
        "@fastify/swagger-ui": "^3.0.0",
        "@node-rs/argon2": "^1.7.2",
        "aws-sdk": "^2.1600.0",
        "bullmq": "^5.4.2",
        "drizzle-orm": "^0.30.10",
        "fastify": "^4.27.0",
        "ioredis": "^5.3.2",
        "nodemailer": "^6.9.13",
        "otplib": "^12.0.1",
        "pdfkit": "^0.17.2",
        "pg": "^8.11.5",
        "pino": "^9.1.0",
        "pino-pretty": "^11.0.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@compliance-os/types": "workspace:*",
        "@testcontainers/postgresql": "^10.7.2",
        "@types/node": "^20.12.12",
        "@types/nodemailer": "^6.4.15",
        "@types/pdfkit": "^0.17.5",
        "@types/pg": "^8.11.6",
        "@vitest/coverage-v8": "^1.6.0",
        "drizzle-kit": "^0.20.18",
        "rimraf": "^5.0.5",
        "testcontainers": "^10.7.2",
        "tsup": "^8.0.2",
        "tsx": "^4.10.5",
        "typescript": "^5.4.5",
        "vitest": "^1.6.0"
    }
}