# App
NODE_ENV=development
PORT=4002
LOG_LEVEL=info

# Banco
DATABASE_URL=postgresql://sanctions:sanctions123@localhost:5432/sanctions_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Segurança
SANCTIONS_API_KEY=troque-em-producao
SANCTIONS_ADMIN_KEY=troque-em-producao

# CGU Brasil
CGU_API_KEY=sua-chave-gratuita-cgu

# Matching
SCREENING_MIN_SCORE=70
SCREENING_CONFIRMED_THRESHOLD=80
SCREENING_CACHE_TTL=3600

# ETL
SYNC_CONCURRENCY=2
INTERPOL_RATE_LIMIT_MS=500

# Fontes ativas
SOURCE_OFAC_SDN=true
SOURCE_OFAC_CONSOLIDATED=true
SOURCE_UN_SC=true
SOURCE_EU_FSF=true
SOURCE_UK_OFSI=true
SOURCE_CGU_CEIS=true
SOURCE_CGU_CNEP=true
SOURCE_CGU_CEPIM=true
SOURCE_INTERPOL_RED=true
