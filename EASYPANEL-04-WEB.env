# --- CONFIGURAÇÃO FRONTEND (NEXT.JS) ---
NODE_ENV=production

# URL Pública da API (Obrigatório para o Login funcionar)
# Deve ser a URL que o NAVEGADOR do usuário consegue acessar
NEXT_PUBLIC_API_URL=https://api.complianceos.com.br

# Ambiente da aplicação
NEXT_PUBLIC_APP_ENV=production

# Porta interna do container (Easypanel mapeia para 80/443)
PORT=3000
HOSTNAME=0.0.0.0
