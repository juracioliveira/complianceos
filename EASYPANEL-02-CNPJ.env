NODE_ENV=production
PORT=4001
LOG_LEVEL=info

# Troque a senha do BD e do Redis se necessário. Estas são as que você forneceu do Easypanel.
DATABASE_URL=postgresql://compliance_app:app_password_dev@complian-os_db-api-complianceos:5432/compliance?sslmode=disable
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

REDIS_URL=redis://default:259f347ec54280725b2c@complian-os_redis-api-complianceos:6379

CNPJ_API_KEY=mude-essa-chave-secreta-em-producao-cnpj
CNPJ_ADMIN_KEY=mude-essa-chave-secreta-em-producao-admin

RFB_BASE_URL=https://arquivos.receitafederal.gov.br/dados/cnpj/dados_abertos_cnpj
RFB_DOWNLOAD_DIR=/tmp/rfb
RFB_DOWNLOAD_CONCURRENCY=3
RFB_DOWNLOAD_RETRIES=5

SYNC_CRON="0 3 5 * *"
# Deixe vazio
SYNC_FORCE_COMPETENCIA=
